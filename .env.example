# ==========================================================================
# Spendes API — environment configuration
# Copy this file to `.env` and adjust values. `.env` is git-ignored.
# The app validates these on boot (see src/config/env.validation.ts) and
# refuses to start if anything required is missing or malformed.
# ==========================================================================

# ---- Application ----
NODE_ENV=development          # development | production | test | staging
PORT=3000
APP_NAME=Spendes API
API_PREFIX=api                # routes are served under /<prefix>/v<version>
API_VERSION=1
CORS_ORIGINS=*                # comma-separated origins, or * for all
LOG_LEVEL=info                # fatal | error | warn | info | debug | trace

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/spendes
MONGODB_DB_NAME=spendes

# ---- Redis (optional — keep disabled until the caching layer is introduced) ----
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=spendes:

# ---- JWT (generate strong secrets, e.g. `openssl rand -hex 32`) ----
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_at_least_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- Security ----
BCRYPT_SALT_ROUNDS=10

# ---- OTP / phone verification ----
OTP_LENGTH=6                  # digits per code (4-8)
OTP_TTL_SECONDS=300           # how long a code stays valid
OTP_MAX_ATTEMPTS=5            # wrong tries before the code is burned
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MOCK_ENABLED=true         # true: every code = OTP_MOCK_CODE and is logged, not sent
OTP_MOCK_CODE=123456          # fixed code used while mocking (dev)

# ---- SMS gateway (only `console` is implemented today) ----
SMS_PROVIDER=console          # console | twilio | msg91
SMS_FROM=Spendes              # sender id / from-number

# ---- Payments / settle-up rail (only `upi_intent` is implemented today) ----
PAYMENT_PROVIDER=upi_intent   # upi_intent (UPI deep link, no license) | razorpay | cashfree

# ---- Monetization / entitlements ----
# Keep false through the MVP: every plan gets every feature (gating is a pass-through).
# Flip to true when the Pro tier + billing ship to turn paid gating on — no code change.
ENTITLEMENTS_ENFORCED=false

# ---- Phone numbering (India MVP; widen ALLOWED list to go global) ----
PHONE_DEFAULT_DIAL_CODE=+91   # assumed when the client omits a dial code
PHONE_ALLOWED_DIAL_CODES=+91  # comma-separated, or * to accept any country

# ---- Rate limiting (window in seconds, max requests per window) ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- API docs ----
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
